{
  "expo": {
    "name": "Beast Tribe",
    "slug": "beast-tribe",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "beasttribe",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/images/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#023C3C"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.operationbeast.beasttribe",
      "infoPlist": {
        "NSPhotoLibraryUsageDescription": "Beast Tribe needs access to your photos to share workout progress.",
        "NSCameraUsageDescription": "Beast Tribe uses the camera for progress photos.",
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "package": "com.operationbeast.beasttribe",
      "adaptiveIcon": {
        "backgroundColor": "#023C3C",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO",
        "android.permission.CAMERA",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.RECORD_AUDIO"
      ]
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-image-picker"
    ],
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "eas": {
        "projectId": "b9a69ad8-8fff-4877-a53b-3c9162c431b7"
      },
      "router": {}
    },
    "owner": "ryo1987",
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "updates": {
      "url": "https://u.expo.dev/b9a69ad8-8fff-4877-a53b-3c9162c431b7"
    }
  }
}
