    "expo": "~55.0.8",
    "expo-camera": "^55.0.11",
    "expo-constants": "~55.0.9",
    "expo-font": "~55.0.4",
    "expo-haptics": "^55.0.9",
    "expo-image-picker": "~55.0.13",
    "expo-linear-gradient": "^55.0.9",
    "expo-linking": "~55.0.8",
    "expo-router": "~55.0.7",
    "expo-splash-screen": "~55.0.12",
